local function isVisible(target)
    if not target or not target:FindFirstChild("Head") then return false end
    local parts = camera:GetPartsObscuringTarget({target.Head.Position}, {localPlayer.Character, target})
    return #parts == 0
end

local function getClosestTarget()
    local closest, dist = nil, fovRadius
    for _, m in pairs(Workspace:GetChildren()) do
        if m:IsA("Model") and (m.Name == "Male" or string.find(m.Name:lower(), "zombie")) then
            if m == localPlayer.Character then continue end
            local head = m:FindFirstChild("Head")
            if head then
                local pos, onScreen = camera:WorldToViewportPoint(head.Position)
                if onScreen then
                    local d = (Vector2.new(pos.X, pos.Y) - centerPosition).Magnitude
                    if d < dist and isVisible(m) then
                        closest = m
                        dist = d
                    end
                end
            end
        end
    end
    return closest
end

-- Hook Engine
task.spawn(function()
    pcall(function()
        local getMuzzle = filtergc('function', {Name = 'GetMuzzleCFrame'}, true)
        if getMuzzle then
            hookfunction(getMuzzle, function(self, cast)
                local origin, barrel, cameraCF = getMuzzle(self, cast)
                if silentAimEnabled and not cast then
                    local target = getClosestTarget()
                    if target and target:FindFirstChild("Head") then
                        return CFrame.new(origin.Position, target.Head.Position), barrel, cameraCF
                    end
                end
                return origin, barrel, cameraCF
            end)
        end
    end)
end)

