-- [[ CORE VISUAL LOGIC ]]
------------------------------------------------------------------
local function applyVisuals(model)
    if not model:IsA("Model") or model == localPlayer.Character then return end
    
    -- Phân loại: Kiểm tra xem Model "Male" này có phải là Player thật không
    local isActualPlayer = false
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character == model then
            isActualPlayer = true
            break
        end
    end

    local isZombie = string.find(model.Name:lower(), "zombie") ~= nil
    local isMale = (model.Name == "Male")
    
    if not isMale and not isZombie then return end

    -- Thiết lập màu sắc
    local targetColor = isZombie and zombieColor or maleColor
    if isActualPlayer then targetColor = playerEspColor end

    -- 1. Highlight Logic
    local highlight = model:FindFirstChild("Tokai_Highlight")
    local shouldShowOutline = (isActualPlayer and playerOutlineEnabled) or (not isActualPlayer and npcOutlineEnabled)
    
    if shouldShowOutline then
        if not highlight then
            highlight = Instance.new("Highlight")
            highlight.Name = "Tokai_Highlight"
            highlight.Parent = model
        end
        highlight.FillColor = targetColor
        highlight.OutlineColor = Color3.new(1, 1, 1)
        highlight.FillTransparency = 0.7
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    else
        if highlight then highlight:Destroy() end
    end

    -- 2. Head Dot Logic
    local head = model:FindFirstChild("Head")
    if head then
        local dot = head:FindFirstChild("Tokai_Dot")
        local shouldShowDot = (isActualPlayer and playerHeadDotEnabled) or (not isActualPlayer and npcEspEnabled)
        
        if shouldShowDot then
            if not dot then
                dot = Instance.new("SphereHandleAdornment")
                dot.Name = "Tokai_Dot"
                dot.Parent = head
                dot.Adornee = head
                dot.Radius = 0.7
                dot.AlwaysOnTop = true
                dot.ZIndex = 10
            end
            dot.Color3 = targetColor
            dot.Transparency = 0.3
        else
            if dot then dot:Destroy() end
        end
    end
end

