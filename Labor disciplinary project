task.spawn(function()
    while not isUnloaded do
        for model, data in pairs(activeNPCs) do
            if not model.Parent then
                activeNPCs[model] = nil
            else
                if outlineEnabled then applyOutline(model) end
            end
        end
        task.wait(0.5)
    end
end)

task.spawn(function()
    while not isUnloaded do
        if silentEnabled then
            for model, data in pairs(activeNPCs) do
                if model.Parent and data.root then applySilentHitbox(model, data.root) end
            end
        else
            for model, _ in pairs(originalSizes) do restoreOriginalSize(model) end
        end
        task.wait(0.1)
    end
end)

task.spawn(function()
    while not isUnloaded do
        if fastScanEnabled then
            local items = Workspace:GetDescendants()
            for i, m in ipairs(items) do
                if not fastScanEnabled or isUnloaded then break end
                if m:IsA("Model") and not activeNPCs[m] and isValidNPC(m) then
                    addNPC(m)
                end
                if i % 300 == 0 then task.wait() end 
            end
        end
        task.wait(0.001)
    end
end)

