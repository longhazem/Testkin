--[[
    FINAL FLY SCRIPT (STABLE & BYPASS)
    - Hướng dẫn: Nhấn phím 'F' để Bật/Tắt bay.
    - Điều khiển: W,A,S,D, Space (Lên), L-Shift (Xuống).
]]

local player = game:GetService("Players").LocalPlayer
local mouse = player:GetMouse()
local runService = game:GetService("RunService")
local uis = game:GetService("UserInputService")

local flying = false
local speed = 200
local bv, bg
local control = {f = 0, b = 0, l = 0, r = 0, u = 0, d = 0}

-- Hàm tạo các đối tượng vật lý để bay
local function startFly()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    flying = true
    
    -- Giữ nhân vật không bị xoay tròn
    bg = Instance.new("BodyGyro")
    bg.P = 9e4
    bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    bg.CFrame = hrp.CFrame
    bg.Parent = hrp

    -- Tạo lực đẩy di chuyển
    bv = Instance.new("BodyVelocity")
    bv.Velocity = Vector3.new(0, 0, 0)
    bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    bv.Parent = hrp

    -- Vòng lặp cập nhật vị trí
    task.spawn(function()
        while flying do
            runService.RenderStepped:Wait()
            if hrp and bg and bv then
                -- Luôn xoay theo hướng Camera
                bg.CFrame = workspace.CurrentCamera.CFrame
                
                -- Tính toán hướng di chuyển
                local camera = workspace.CurrentCamera
                local moveDir = (camera.CFrame.LookVector * (control.f + control.b) + 
                                camera.CFrame.RightVector * (control.r + control.l) + 
                                Vector3.new(0, control.u + control.d, 0))
                
                if moveDir.Magnitude > 0 then
                    bv.Velocity = moveDir.Unit * speed
                else
                    bv.Velocity = Vector3.new(0, 0, 0)
                end
            end
        end
    end)
    
    -- Cơ chế Bypass: Nháy xuống đất để tránh Anti-Cheat (giống trong ảnh bạn gửi)
    task.spawn(function()
        while flying do
            task.wait(2) -- Cứ mỗi 2 giây thực hiện nháy 1 lần
            if flying and hrp then
                local oldPos = hrp.CFrame
                -- Bắn tia laser tìm mặt đất
                local ray = Ray.new(hrp.Position, Vector3.new(0, -500, 0))
                local hit, pos = workspace:FindPartOnRayWithIgnoreList(ray, {char})
                
                if hit then
                    hrp.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0)) -- Chạm đất
                    task.wait(0.1)
                    hrp.CFrame = oldPos -- Quay lại vị trí bay
                end
            end
        end
    end)
end

local function stopFly()
    flying = false
    if bg then bg:Destroy() end
    if bv then bv:Destroy() end
end

-- Bắt sự kiện bàn phím
uis.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    
    if input.KeyCode == Enum.KeyCode.F then -- Nhấn F để bật/tắt
        if flying then stopFly() else startFly() end
    elseif input.KeyCode == Enum.KeyCode.W then control.f = 1
    elseif input.KeyCode == Enum.KeyCode.S then control.b = -1
    elseif input.KeyCode == Enum.KeyCode.A then control.l = -1
    elseif input.KeyCode == Enum.KeyCode.D then control.r = 1
    elseif input.KeyCode == Enum.KeyCode.Space then control.u = 1
    elseif input.KeyCode == Enum.KeyCode.LeftShift then control.d = -1
    end
end)

uis.InputEnded:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.W then control.f = 0
    elseif input.KeyCode == Enum.KeyCode.S then control.b = 0
    elseif input.KeyCode == Enum.KeyCode.A then control.l = 0
    elseif input.KeyCode == Enum.KeyCode.D then control.r = 0
    elseif input.KeyCode == Enum.KeyCode.Space then control.u = 0
    elseif input.KeyCode == Enum.KeyCode.LeftShift then control.d = 0
    end
end)

print("Fly Script Loaded! Press 'F' to fly.")
