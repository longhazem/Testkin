--[[ 
    BRM5 ULTIMATE FLY V3 (BYPASS CHARACTER CONTROLLER)
    Hỗ trợ: Mobile & PC
    Cơ chế: Can thiệp vào Module di chuyển của game để mở khóa tọa độ.
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- Biến trạng thái
getgenv().FlySettings = {
    Active = false,
    Speed = 50,
    ElevateSpeed = 30
}

local moveState = {up = false, down = false}

-- Hàm tìm kiếm Module di chuyển của BRM5 để vô hiệu hóa
local function toggleGameController(state)
    local PlayerScripts = LocalPlayer:WaitForChild("PlayerScripts")
    -- BRM5 thường để logic di chuyển trong các Module này
    local Controller = PlayerScripts:FindFirstChild("CharacterController", true) or PlayerScripts:FindFirstChild("ControlModule", true)
    
    if Controller and Controller:IsA("ModuleScript") then
        local success, mod = pcall(require, Controller)
        if success and type(mod) == "table" then
            -- Tùy phiên bản game, chúng ta vô hiệu hóa hàm Update hoặc Disable
            if mod.Update then
                if state == false then
                    if not getgenv().OldUpdate then getgenv().OldUpdate = mod.Update end
                    mod.Update = function() end -- Làm trống hàm cập nhật của game
                else
                    if getgenv().OldUpdate then mod.Update = getgenv().OldUpdate end
                end
            end
        end
    end
end

-- UI cho Mobile & PC
local function createUI()
    if LocalPlayer.PlayerGui:FindFirstChild("FlyV3") then LocalPlayer.PlayerGui.FlyV3:Destroy() end
    
    local sg = Instance.new("ScreenGui", LocalPlayer.PlayerGui)
    sg.Name = "FlyV3"
    sg.ResetOnSpawn = false
    
    local main = Instance.new("Frame", sg)
    main.Size = UDim2.new(0, 150, 0, 180)
    main.Position = UDim2.new(0.05, 0, 0.4, 0)
    main.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    main.Active = true
    main.Draggable = true
    Instance.new("UICorner", main)

    local title = Instance.new("TextLabel", main)
    title.Size = UDim2.new(1, 0, 0, 30)
    title.Text = "BRM5 FLY V3"
    title.TextColor3 = Color3.new(1, 1, 1)
    title.BackgroundTransparency = 1
    title.Font = Enum.Font.GothamBold

    local toggle = Instance.new("TextButton", main)
    toggle.Size = UDim2.new(0.9, 0, 0, 40)
    toggle.Position = UDim2.new(0.05, 0, 0.25, 0)
    toggle.Text = "FLY: OFF"
    toggle.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
    toggle.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", toggle)

    local speedBox = Instance.new("TextBox", main)
    speedBox.Size = UDim2.new(0.9, 0, 0, 30)
    speedBox.Position = UDim2.new(0.05, 0, 0.5, 0)
    speedBox.Text = "50"
    speedBox.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    speedBox.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", speedBox)

    local up = Instance.new("TextButton", main)
    up.Size = UDim2.new(0.42, 0, 0, 40)
    up.Position = UDim2.new(0.05, 0, 0.7, 0)
    up.Text = "UP"
    up.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    up.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", up)

    local down = Instance.new("TextButton", main)
    down.Size = UDim2.new(0.42, 0, 0, 40)
    down.Position = UDim2.new(0.53, 0, 0.7, 0)
    down.Text = "DOWN"
    down.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    down.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", down)

    -- Sự kiện nút
    up.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then moveState.up = true end end)
    up.InputEnded:Connect(function() moveState.up = false end)
    down.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then moveState.down = true end end)
    down.InputEnded:Connect(function() moveState.down = false end)
    speedBox.FocusLost:Connect(function() getgenv().FlySettings.Speed = tonumber(speedBox.Text) or 50 end)

    return toggle
end

local flyLoop
local function startFly()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart")
    local hum = char:WaitForChild("Humanoid")

    -- Bước 1: Vô hiệu hóa Controller của game
    toggleGameController(false)
    
    -- Bước 2: Dùng Anchor để giữ nhân vật (Bypass vật lý game)
    root.Anchored = true
    hum.PlatformStand = true

    flyLoop = RunService.Heartbeat:Connect(function(dt)
        if not getgenv().FlySettings.Active or not char.Parent then
            if flyLoop then flyLoop:Disconnect() end
            root.Anchored = false
            hum.PlatformStand = false
            toggleGameController(true) -- Trả lại quyền điều khiển cho game
            return
        end

        local moveDir = Vector3.new(0, 0, 0)
        local camCF = Camera.CFrame

        -- Nhận diện Joystick (Cực kỳ quan trọng cho Mobile)
        local moveInput = hum.MoveDirection
        if moveInput.Magnitude > 0 then
            moveDir = moveDir + moveInput
        end

        -- Nút bổ trợ
        if moveState.up then moveDir = moveDir + Vector3.new(0, 1, 0) end
        if moveState.down then moveDir = moveDir - Vector3.new(0, 1, 0) end

        -- Cập nhật tọa độ trực tiếp
        if moveDir.Magnitude > 0 then
            root.CFrame = root.CFrame + (moveDir * getgenv().FlySettings.Speed * dt)
        end

        -- Luôn xoay theo hướng Camera
        root.CFrame = CFrame.new(root.CFrame.Position, root.CFrame.Position + Vector3.new(camCF.LookVector.X, 0, camCF.LookVector.Z))
    end)
end

local btn = createUI()
btn.MouseButton1Click:Connect(function()
    getgenv().FlySettings.Active = not getgenv().FlySettings.Active
    if getgenv().FlySettings.Active then
        btn.Text = "FLY: ON"
        btn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        startFly()
    else
        btn.Text = "FLY: OFF"
        btn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
    end
end)

print("BRM5 Ultimate Fly Loaded! Nếu không bay được, hãy thử nhảy 1 lần rồi bật.")
