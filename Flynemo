-- Khởi tạo cài đặt tốc độ (Bạn có thể thay đổi các giá trị này)
local SpeedSettings = {
    WalkSpeedMult = 2,    -- Gấp 2 lần tốc độ đi bộ mặc định
    SprintSpeedMult = 3,  -- Gấp 3 lần tốc độ chạy nhanh mặc định
    NoMovementPenalty = true -- Loại bỏ hình phạt giảm tốc độ khi trúng đạn/vác nặng
}

local function findModule(name)
    local RF = game:GetService("ReplicatedFirst")
    local RS = game:GetService("ReplicatedStorage")
    local function search(parent)
        if not parent then return end
        for _, child in ipairs(parent:GetChildren()) do
            if (child.Name:find(name) or child.Name:lower():find(name:lower())) and child:IsA("ModuleScript") then
                return child
            end
            local found = search(child)
            if found then return found end
        end
    end
    return search(RF) or search(RS)
end

task.spawn(function()
    local CharacterController = nil
    while true do
        if not CharacterController then
            local mod = findModule("CharacterController")
            if mod then
                local success, result = pcall(require, mod)
                if success and result and result.Update then
                    CharacterController = result
                    
                    -- Bắt đầu Hook hàm Update để can thiệp tốc độ
                    local oldUpdate = CharacterController.Update
                    CharacterController.Update = function(self, inputVector, deltaTime)
                        if not self or not self._localActor then 
                            return oldUpdate(self, inputVector, deltaTime) 
                        end

                        -- 1. Loại bỏ hình phạt di chuyển (nếu bật)
                        if SpeedSettings.NoMovementPenalty then
                            self._localActor.SpeedPenalty = 1
                        end

                        -- 2. Tính toán và áp dụng hệ số nhân tốc độ
                        local baseWeight = self._weightMulti or 1
                        local walkMult = SpeedSettings.WalkSpeedMult or 1
                        local sprintMult = SpeedSettings.SprintSpeedMult or 1
                        
                        -- Kiểm tra đang chạy nhanh hay đi bộ để áp dụng đúng multiplier
                        local activeMult = self.IsSprinting and sprintMult or walkMult

                        -- Ghi đè trọng số di chuyển (weightMulti) để tăng tốc độ vật lý
                        self._weightMulti = baseWeight * activeMult

                        -- Chạy hàm gốc với tốc độ đã được sửa đổi
                        local res = oldUpdate(self, inputVector, deltaTime)

                        -- Khôi phục lại trọng số gốc để tránh lỗi logic game ở frame sau
                        self._weightMulti = baseWeight
                        
                        return res
                    end
                    print("✓ Đã tách và kích hoạt logic Speed thành công!")
                    break 
                end
            end
        end
        task.wait(2)
    end
end)
