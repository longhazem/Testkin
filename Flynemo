local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "TOKAI Hub | Speed Bypass",
   LoadingTitle = "Loading Script...",
   LoadingSubtitle = "by LONGTOKAI",
   ConfigurationSaving = { Enabled = false }
})

local Tab = Window:CreateTab("Main", 4483362458)

local WalkSpeedSettings = {
    Enabled = false,
    Speed = 35
}

Tab:CreateToggle({
   Name = "Bật/Tắt Tốc Độ",
   CurrentValue = false,
   Callback = function(Value)
      WalkSpeedSettings.Enabled = Value
   end,
})

Tab:CreateInput({
   Name = "Nhập Tốc Độ",
   PlaceholderText = "Mặc định: 16 | Hiện tại: 35",
   RemoveTextAfterFocusLost = false,
   Callback = function(Text)
      local num = tonumber(Text)
      if num then
          WalkSpeedSettings.Speed = num
      else
          Rayfield:Notify({Title = "Lỗi", Content = "Vui lòng chỉ nhập số!", Duration = 3})
      end
   end,
})

local RunService = game:GetService("RunService")
local LocalPlayer = game:GetService("Players").LocalPlayer

RunService.Heartbeat:Connect(function(Delta)
    if not WalkSpeedSettings.Enabled then return end
    
    local Character = LocalPlayer.Character
    local Humanoid = Character and Character:FindFirstChild("Humanoid")
    local RootPart = Character and Character:FindFirstChild("HumanoidRootPart")
    
    if Humanoid and RootPart and Humanoid.Health > 0 then
        if Humanoid.MoveDirection.Magnitude > 0 then
            local SpeedDifference = (WalkSpeedSettings.Speed - Humanoid.WalkSpeed)
            if SpeedDifference > 0 then
                RootPart.CFrame = RootPart.CFrame + (Humanoid.MoveDirection * (SpeedDifference * Delta))
            end
        end
    end
end)
