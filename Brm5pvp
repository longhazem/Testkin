-- ESP & UI
---------------------------------------------------------
local function ensureHighlight(model)
    if model:IsA("Model") and model.Name == "Male" then
        local hl = model:FindFirstChild("AutoHighlight") or Instance.new("Highlight", model)
        hl.Name = "AutoHighlight"
        hl.FillColor = Color3.new(1, 1, 0)
        hl.Enabled = Options.ESP
    end
end
Workspace.DescendantAdded:Connect(ensureHighlight)

local ScreenGui = Instance.new("ScreenGui", CoreGui)
local Main = Instance.new("Frame", ScreenGui)
Main.Size = UDim2.new(0, 240, 0, 340)
Main.Position = UDim2.new(0.5, -120, 0.5, -170)
Main.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
Instance.new("UICorner", Main)

local function CreateToggle(text, pos, callback, state)
    local btn = Instance.new("TextButton", Main)
    btn.Size = UDim2.new(0.9, 0, 0, 32)
    btn.Position = pos
    btn.BackgroundColor3 = state and Color3.fromRGB(40, 150, 40) or Color3.fromRGB(150, 40, 40)
    btn.Text = text .. (state and ": ON" or ": OFF")
    btn.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = text .. (state and ": ON" or ": OFF")
        btn.BackgroundColor3 = state and Color3.fromRGB(40, 150, 40) or Color3.fromRGB(150, 40, 40)
        callback(state)
    end)
end

CreateToggle("Silent Aim", UDim2.new(0.05, 0, 0, 45), function(s) Options.SilentAim = s end, Options.SilentAim)
CreateToggle("NPC ESP", UDim2.new(0.05, 0, 0, 85), function(s) Options.ESP = s end, Options.ESP)
CreateToggle("Show FOV", UDim2.new(0.05, 0, 0, 125), function(s) Options.ShowFov = s end, Options.ShowFov)

-- Slider FOV
local SliderBG = Instance.new("Frame", Main)
SliderBG.Size = UDim2.new(0.9, 0, 0, 8)
SliderBG.Position = UDim2.new(0.05, 0, 0, 185)
SliderBG.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
local SliderFill = Instance.new("Frame", SliderBG)
SliderFill.Size = UDim2.new(Options.FovRadius/500, 0, 1, 0)
SliderFill.BackgroundColor3 = Color3.fromRGB(0, 120, 255)

SliderBG.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        local connection
        connection = RunService.RenderStepped:Connect(function()
            local inputPos = UserInputService:GetMouseLocation().X
            local relPos = math.clamp((inputPos - SliderBG.AbsolutePosition.X) / SliderBG.AbsoluteSize.X, 0, 1)
            SliderFill.Size = UDim2.new(relPos, 0, 1, 0)
            Options.FovRadius = math.floor(relPos * 500)
            if not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then connection:Disconnect() end
        end)
    end
end)

CreateToggle("Hitbox Mod", UDim2.new(0.05, 0, 0, 210), function(s) Options.Hitbox = s end, Options.Hitbox)

local Float = Instance.new("TextButton", ScreenGui)
Float.Size = UDim2.new(0, 100, 0, 40)
Float.Position = UDim2.new(0.8, 0, 0.2, 0)
Float.Text = "Aim: HEAD"
Float.BackgroundColor3 = Color3.fromRGB(255, 100, 0)
Instance.new("UICorner", Float)
Float.MouseButton1Click:Connect(function()
    if Options.AimPart == "Head" then
        Options.AimPart = "Torso"; Float.Text = "Aim: BODY"; Float.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
    else
        Options.AimPart = "Head"; Float.Text = "Aim: HEAD"; Float.BackgroundColor3 = Color3.fromRGB(255, 100, 0)
    end
    if Options.Hitbox then ResetHitboxes() end
end)

task.spawn(function()
    while true do
        pcall(ApplyHitbox)
        task.wait(0.5)
    end
end)
