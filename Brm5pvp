-- ESP HIGHLIGHT & LOOP
local function ensureHighlight(model)
    if model:IsA("Model") and model.Name == "Male" then
        local hl = model:FindFirstChild("AutoHighlight") or Instance.new("Highlight", model)
        hl.Name = "AutoHighlight"
        hl.FillColor = Color3.new(1, 1, 0)
        hl.Enabled = Options.ESP
    end
end
Workspace.DescendantAdded:Connect(ensureHighlight)
for _, v in pairs(Workspace:GetDescendants()) do ensureHighlight(v) end

