---------------------------------------------------------
-- LOGIC CLIENT SERVICE & SILENT AIM
---------------------------------------------------------
local Functions = {
    GetClients = filtergc('function', {Name = 'GetClients', Constants = {'Clients'}}, false),
    GetMuzzleCFrame = filtergc('function', {Name = 'GetMuzzleCFrame'}, true),
    GetRecoil = filtergc('function', {Name = 'getRecoil'}, true)
}

local ClientService = nil

for _, Function in pairs(Functions.GetClients) do
    local Info = getinfo(Function)
    if not Info.source:find('ClientService') then continue end
    Functions.GetClients = Function
end

local OldClients; OldClients = hookfunction(Functions.GetClients, function(Self)
    ClientService = Self; return OldClients(Self)
end)

local function GetActorPart(Data)
    if not Data or not Data.Actor or not Data.Actor.Parts then return nil end
    local Parts = Data.Actor.Parts
    return (Options.AimPart == "Head") and Parts.Head or (Parts.Torso or Parts.UpperTorso or Parts.HumanoidRootPart)
end

function GetClosest()
    local ClosestPlayer, ClosestData, ClosestDistance = nil, nil, math.huge
    if not ClientService then return end

    for Player, Data in pairs(ClientService.Clients) do
        if Player == LocalPlayer then continue end
        if not Data.Actor or not Data.Actor.Alive then continue end
        if Data.Squad == ClientService.LocalClient.Squad then continue end

        local targetPart = GetActorPart(Data)
        if not targetPart then continue end

        local Position, OnScreen = Camera:WorldToViewportPoint(targetPart.Position)
        if not OnScreen then continue end

        local Distance = (Vector2.new(Position.X, Position.Y) - (Camera.ViewportSize / 2)).Magnitude
        if Distance > Options.FovRadius or Distance > ClosestDistance then continue end

        ClosestPlayer = Player; ClosestData = Data; ClosestDistance = Distance
    end
    return ClosestPlayer, ClosestData
end

local OldMuzzle; OldMuzzle = hookfunction(Functions.GetMuzzleCFrame, function(Self, Cast)
    local Origin, Barrel, CameraCF = OldMuzzle(Self, Cast)
    if Options.SilentAim and not Cast and Origin then
        local Player, Data = GetClosest()
        if Player then
            local targetPart = GetActorPart(Data)
            if targetPart then
                return CFrame.new(Origin.Position, targetPart.Position), Barrel, CameraCF
            end
        end
    end
    return Origin, Barrel, CameraCF
end)

local OldRecoil; OldRecoil = hookfunction(Functions.GetRecoil, function(...)
    local Args = {...}
    if Options.SilentAim and Args[1] then
        Args[1]['Barrel_Spread'] = 0; Args[1]['RecoilForce_Tap'] = 0
    end
    return OldRecoil(unpack(Args))
end)

---------------------------------------------------------
-- HITBOX EXPANDER (FIXED FOR CLIENTSERVICE)
---------------------------------------------------------
local ModifiedParts = {}
local OriginalSizes = {}

-- Metatable Bypass cho Size
local mt = getrawmetatable(game)
local old_index = mt.__index
setreadonly(mt, false)
mt.__index = newcclosure(function(t, k)
    if k == "Size" and ModifiedParts[t] then return OriginalSizes[t] end
    return old_index(t, k)
end)
setreadonly(mt, true)

local function ResetHitboxes()
    for part, size in pairs(OriginalSizes) do
        if part and part.Parent then
            part.Size = size
            part.Transparency = 0
        end
    end
    table.clear(ModifiedParts)
    table.clear(OriginalSizes)
end

local function ApplyHitbox()
    if not Options.Hitbox or not ClientService then 
        if next(ModifiedParts) then ResetHitboxes() end
        return 
    end

    local sizeVec = Vector3.new(Options.HitboxSize, Options.HitboxSize, Options.HitboxSize)
    
    -- Quét qua danh sách Client của game thay vì Workspace
    for _, Data in pairs(ClientService.Clients) do
        if Data.Actor and Data.Actor.Alive and Data.Squad ~= ClientService.LocalClient.Squad then
            local target = GetActorPart(Data)
            
            if target and target:IsA("BasePart") then
                if not ModifiedParts[target] then
                    ModifiedParts[target] = true
                    OriginalSizes[target] = target.Size
                    target.CanCollide = false
                end
                target.Size = sizeVec
                target.Transparency = 0.5
            end
        end
    end
end

