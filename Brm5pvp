---------------------------------------------------------
-- HITBOX EXPANDER (BYPASS SIZE)
---------------------------------------------------------
local ModifiedParts = {}
local OriginalSizes = {}

local mt = getrawmetatable(game)
local old_index = mt.__index
setreadonly(mt, false)

mt.__index = newcclosure(function(t, k)
    if k == "Size" and ModifiedParts[t] then
        return OriginalSizes[t] or Vector3.new(1, 1, 1)
    end
    return old_index(t, k)
end)
setreadonly(mt, true)

local function ResetHitboxes()
    for part, size in pairs(OriginalSizes) do
        if part and part.Parent then
            part.Size = size
            part.Transparency = 0
            part.CanCollide = true
        end
    end
    table.clear(ModifiedParts)
    table.clear(OriginalSizes)
end

local function ApplyHitbox()
    if not Options.Hitbox then
        if next(ModifiedParts) then ResetHitboxes() end
        return 
    end

    local sizeVec = Vector3.new(Options.HitboxSize, Options.HitboxSize, Options.HitboxSize)
    for _, model in pairs(Workspace:GetChildren()) do
        if model:IsA("Model") and model.Name == "Male" then
            local target = (Options.AimPart == "Head") and model:FindFirstChild("Head") or 
                           (model:FindFirstChild("Torso") or model:FindFirstChild("UpperTorso") or model:FindFirstChild("HumanoidRootPart"))
            
            if target and target:IsA("BasePart") then
                if not ModifiedParts[target] then
                    ModifiedParts[target] = true
                    OriginalSizes[target] = target.Size
                    target.CanCollide = false
                    target.Transparency = 0.5
                end
                if target.Size ~= sizeVec then target.Size = sizeVec end
            end
        end
    end
end

---------------------------------------------------------
-- ESP HIGHLIGHT
---------------------------------------------------------
local function ensureHighlight(model)
    if model:IsA("Model") and model.Name == "Male" then
        local hl = model:FindFirstChild("AutoHighlight")
        if not hl then
            hl = Instance.new("Highlight")
            hl.Name = "AutoHighlight"
            hl.FillColor = Color3.fromRGB(255, 255, 0)
            hl.OutlineColor = Color3.fromRGB(255, 255, 255)
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hl.Parent = model
        end
        hl.Enabled = Options.ESP
    end
end

Workspace.DescendantAdded:Connect(ensureHighlight)
for _, v in pairs(Workspace:GetDescendants()) do ensureHighlight(v) end

---------------------------------------------------------
-- SILENT AIM (FIXED)
---------------------------------------------------------
local function GetClosestTarget()
    local target, dist = nil, math.huge
    for _, model in pairs(Workspace:GetChildren()) do
        if model:IsA("Model") and model.Name == "Male" then
            local part = (Options.AimPart == "Head") and model:FindFirstChild("Head") or 
                         (model:FindFirstChild("Torso") or model:FindFirstChild("UpperTorso") or model:FindFirstChild("HumanoidRootPart"))
            
            if part then
                local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local mag = (Vector2.new(pos.X, pos.Y) - (Camera.ViewportSize / 2)).Magnitude
                    if mag <= Options.FovRadius and mag < dist then
                        target = part
                        dist = mag
                    end
                end
            end
        end
    end
    return target
end

