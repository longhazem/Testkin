-- LOGIC ESP ĐÃ SỬA LỖI PBR (NPC "Male")
---------------------------------------------------------
local function clearESP()
    for _, object in pairs(Workspace:GetDescendants()) do
        -- Xóa các Box ESP cũ (nếu có)
        if object.Name == "ESP_Visual" then
            object:Destroy()
        end
    end
end

local function highlightMaleModels()
    if not Options.ESP then 
        clearESP()
        return 
    end

    for _, object in pairs(Workspace:GetChildren()) do
        if object:IsA("Model") and object.Name == "Male" then
            -- Thay vì dùng Highlight gây lỗi texture, ta dùng BillboardGui tạo Box ESP
            local targetPart = object:FindFirstChild("HumanoidRootPart") or object:FindFirstChild("Torso") or object.PrimaryPart or object:FindFirstChildWhichIsA("BasePart")
            
            if targetPart and not object:FindFirstChild("ESP_Visual") then
                local bgui = Instance.new("BillboardGui")
                bgui.Name = "ESP_Visual"
                bgui.Adornee = targetPart
                bgui.Size = UDim2.new(4.5, 0, 6, 0) -- Kích thước khung Box bao quanh NPC
                bgui.AlwaysOnTop = true -- Nhìn xuyên tường
                
                local box = Instance.new("Frame")
                box.Size = UDim2.new(1, 0, 1, 0)
                box.BackgroundTransparency = 0.75 -- Độ trong suốt của khung
                box.BackgroundColor3 = Color3.fromRGB(0, 255, 200)
                box.BorderSizePixel = 1.5
                box.BorderColor3 = Color3.fromRGB(255, 255, 255)
                box.Parent = bgui
                
                bgui.Parent = object
            end
        end
    end
end

-- Chạy vòng lặp quét ESP trong luồng riêng
task.spawn(function()
    while true do
        highlightMaleModels()
        task.wait(5)
    end
end)

