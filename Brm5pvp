UserInputService.InputEnded:Connect(function(i) if pressing then pressing = false if not hasDragged then 
    if Options.AimPart == "Head" then Options.AimPart = "Torso"; Float.Text = "Aim: BODY"; Float.BackgroundColor3 = Color3.fromRGB(0, 120, 255) else Options.AimPart = "Head"; Float.Text = "Aim: HEAD"; Float.BackgroundColor3 = Color3.fromRGB(255, 100, 0) end 
    if Options.Hitbox then ResetHitboxes() end end end 
end)

-- KÉO MENU CHÍNH
local mDrag, mStart, mPos = false, nil, nil
Main.InputBegan:Connect(function(i) if (i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch) and not isSliding then mDrag, mStart, mPos = true, i.Position, Main.Position end end)
