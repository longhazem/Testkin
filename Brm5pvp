-- HOOK HỆ THỐNG
---------------------------------------------------------
local function HookFunctions()
    local Success, Functions = pcall(function()
        return {
            GetMuzzle = filtergc('function', {Name = 'GetMuzzleCFrame'}, true),
            GetRecoil = filtergc('function', {Name = 'getRecoil'}, true)
        }
    end)
    
    if not Success or not Functions.GetMuzzle then return end

    hookfunction(Functions.GetMuzzle, function(Self, Cast)
        local Origin, Barrel, CamCF = Functions.GetMuzzle(Self, Cast)
        if Options.SilentAim and not Cast then
            local targetPart = GetClosestTarget()
            if targetPart then
                return CFrame.new(Origin.Position, targetPart.Position), Barrel, CamCF
            end
        end
        return Origin, Barrel, CamCF
    end)

    hookfunction(Functions.GetRecoil, function(...)
        local args = {...}
        if Options.SilentAim and args[1] then
            args[1]['Barrel_Spread'] = 0
            args[1]['RecoilForce_Tap'] = 0
        end
        return Functions.GetRecoil(unpack(args))
    end)
end

task.spawn(function()
    HookFunctions()
    while true do
        pcall(ApplyHitbox)
        task.wait(1)
    end
end)
