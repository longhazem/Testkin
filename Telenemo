-- Cấu hình cơ bản
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera

-- Xóa UI cũ nếu có (để tránh trùng lặp khi chạy script nhiều lần)
if game:GetService("CoreGui"):FindFirstChild("TelekinesisUI") then
    game:GetService("CoreGui").TelekinesisUI:Destroy()
elseif LocalPlayer:WaitForChild("PlayerGui"):FindFirstChild("TelekinesisUI") then
    LocalPlayer.PlayerGui.TelekinesisUI:Destroy()
end

-- Tạo ScreenGui
local SG = Instance.new("ScreenGui")
SG.Name = "TelekinesisUI"
SG.ResetOnSpawn = false
-- Ưu tiên bỏ vào CoreGui để không bị mất khi reset nhân vật, nếu không được thì bỏ vào PlayerGui
local success = pcall(function() SG.Parent = game:GetService("CoreGui") end)
if not success then SG.Parent = LocalPlayer:WaitForChild("PlayerGui") end

-- Tạo Tâm (Crosshair)
local Crosshair = Instance.new("Frame", SG)
Crosshair.Size = UDim2.new(0, 6, 0, 6)
Crosshair.Position = UDim2.new(0.5, -3, 0.5, -3)
Crosshair.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
Crosshair.BorderSizePixel = 0
